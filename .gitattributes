# Always count Fortran
*.f90 linguist-language=Fortran
*.f95 linguist-language=Fortran
*.f03 linguist-language=Fortran
*.f08 linguist-language=Fortran
*.f   linguist-language=Fortran

# PureBasic → mapped to BASIC (best match)
*.pb  linguist-language=Basic
*.pbi linguist-language=Basic

# Optional: hide scripting languages from stats
*.lua linguist-vendored
*.sh  linguist-vendored
*.ps1 linguist-vendored

# Keep Git behavior normal
* text=auto
